    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600&family=Inter:wght@300;400;600;700&display=swap');

        :root {
            --github-dark: #0d1117;
            --github-canvas: #010409;
            --github-border: #30363d;
            --github-blue: #58a6ff;
            --github-green: #238636;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--github-canvas);
            color: #c9d1d9;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
        }

        .nav-item {
            position: relative;
            padding: 8px 16px;
            font-size: 14px;
            color: #8b949e;
            transition: color 0.2s ease;
        }

        .nav-item:hover {
            color: #c9d1d9;
        }

        .nav-item.active {
            color: #f0f6fc;
            font-weight: 600;
        }

        .nav-item.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 100%;
            height: 2px;
            background-color: #f78166;
        }

        .repo-card {
            background-color: var(--github-dark);
            border: 1px solid var(--github-border);
            border-radius: 6px;
            padding: 16px;
            transition: border-color 0.2s ease, transform 0.2s ease;
        }

        .repo-card:hover {
            border-color: #8b949e;
            transform: translateY(-2px);
        }

        .profile-avatar {
            border: 1px solid var(--github-border);
            background-color: var(--github-dark);
            width: 100%;
            border-radius: 50%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            display: block;
        }

        .lang-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            display: inline-block;
        }

        .contribution-box {
            width: 10px;
            height: 10px;
            border-radius: 2px;
            background-color: #161b22;
        }

        .box-level-1 { background-color: #0e4429; }
        .box-level-2 { background-color: #006d32; }
        .box-level-3 { background-color: #26a641; }
        .box-level-4 { background-color: #39d353; }

        .terminal {
            background-color: #0d1117;
            border: 1px solid var(--github-border);
            border-radius: 6px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .cursor {
            display: inline-block;
            width: 8px;
            height: 18px;
            background: var(--github-blue);
            animation: blink 1s infinite;
            vertical-align: middle;
            margin-left: 4px;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        .section-anchor {
            scroll-margin-top: 140px;
        }
    </style>
